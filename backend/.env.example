# ResumeIQ environment variables
# Copy this file to .env and fill in the values

APP_NAME=ResumeIQ
APP_VERSION=1.0.0
DEBUG=true

# SQLite (default — no setup needed)
DATABASE_URL=sqlite:///./resumeiq.db

# IMPORTANT: Change this to a random 32+ character string in production!
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-secret-key-in-production-use-a-long-random-string

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
